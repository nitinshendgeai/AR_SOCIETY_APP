# ─────────────────────────────────────────────────────────────────────────────
# AR Society ERP — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="AR Society ERP"
APP_VERSION="1.0.0"
APP_ENV=development         # development | staging | production
DEBUG=false

# Database (PostgreSQL)
# Railway injects this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/ar_society_db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated or JSON list
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Superadmin seed (optional — auto-create on first startup)
SUPERADMIN_EMAIL=admin@arsociety.com
SUPERADMIN_PASSWORD=Admin@12345

# Migrations
# Set to true on Railway to auto-run alembic upgrade head on boot
RUN_MIGRATIONS=false
