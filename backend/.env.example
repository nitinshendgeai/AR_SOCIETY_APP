# ─────────────────────────────────────────────────────────────────────────────
# AR Society ERP — Environment Variables
# Copy to .env for local development
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="AR Society ERP"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=false

# Database — Railway injects this automatically via PostgreSQL plugin
DATABASE_URL=postgresql://user:password@localhost:5432/ar_society_db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Migrations
# Set to true on Railway to auto-run 'alembic upgrade head' on every deploy
RUN_MIGRATIONS=true

# Superadmin seed (optional)
SUPERADMIN_EMAIL=admin@arsociety.com
SUPERADMIN_PASSWORD=Admin@12345
