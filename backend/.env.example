# ─────────────────────────────────────────────────────────────────────────────
# AR Society ERP — Environment Variables
# Copy to .env for local development. Set these in Railway Variables for prod.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="AR Society ERP"
APP_VERSION="1.0.0"
APP_ENV=production
DEBUG=false

# Database — Railway PostgreSQL (auto-injected by Railway PostgreSQL plugin)
# Format: postgresql://postgres:<PASSWORD>@<HOST>:<PORT>/railway
DATABASE_URL=postgresql://postgres:PASSWORD@kodama.proxy.rlwy.net:57666/railway

# JWT — generate strong key: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — add your frontend domain
ALLOWED_ORIGINS=["*"]

# Migrations — set true on Railway to auto-run 'alembic upgrade head' on deploy
RUN_MIGRATIONS=true

# Superadmin seed (optional)
SUPERADMIN_EMAIL=admin@arsociety.com
SUPERADMIN_PASSWORD=Admin@12345
